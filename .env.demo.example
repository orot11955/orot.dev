# Demo web-only environment
# Copy to `.env.demo` when running the static/localStorage demo web.
#
# Default public routes:
# - Production: https://orot.dev
# - Demo: https://demo.orot.dev
#
# Change SITE_URL, NEXT_PUBLIC_SITE_URL, and WEB_IMAGE_REMOTE_PATTERNS
# together when using a different demo domain.

TZ=Asia/Seoul
DEMO_WEB_PORT=3001

SITE_URL=https://demo.orot.dev
NEXT_PUBLIC_SITE_URL=https://demo.orot.dev
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CLIENT_ERROR_LOGGING=true
CLIENT_ERROR_LOGGING=true

# Demo mode does not call a Nest API, but these keep build/runtime config valid.
INTERNAL_API_ORIGIN=http://127.0.0.1:9
WEB_SERVER_API_TIMEOUT_MS=3000
WEB_IMAGE_REMOTE_PATTERNS=https://demo.orot.dev/**
LOG_LEVEL=info
WEB_LOG_LEVEL=info
LOG_PRETTY=false
WEB_LOG_PRETTY=false
