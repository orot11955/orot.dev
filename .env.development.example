# Root development environment
# Copy to `.env.development` or `.env.development.local` to override locally.

TZ=Asia/Seoul

# Shared app URLs
SITE_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://forge.home:3000

# Shared logging
LOG_LEVEL=debug
LOG_PRETTY=false

# Web app
WEB_PORT=3000
WEB_LOG_LEVEL=debug
WEB_LOG_PRETTY=false
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CLIENT_ERROR_LOGGING=true
CLIENT_ERROR_LOGGING=true
INTERNAL_API_ORIGIN=http://localhost:4000
WEB_SERVER_API_TIMEOUT_MS=3000
WEB_IMAGE_REMOTE_PATTERNS=http://localhost:4000/uploads/**,http://127.0.0.1:4000/uploads/**,http://forge.home/uploads/**,https://orot.dev/uploads/**

# API app
API_PORT=4000
API_DATABASE_URL=mysql://orot:orotpassword@localhost:3306/orot
API_HTTP_LOGGING=true
API_REQUEST_BODY_LIMIT=20mb
API_SLOW_QUERY_MS=300
API_STUDIO_USERNAME=admin
API_STUDIO_PASSWORD=change-me
API_JWT_ACCESS_SECRET=dev-access-secret
API_JWT_REFRESH_SECRET=dev-refresh-secret
API_JWT_ACCESS_EXPIRES_IN=15m
API_JWT_REFRESH_EXPIRES_IN=30d
API_COOKIE_DOMAIN=
API_COOKIE_SECURE=false
