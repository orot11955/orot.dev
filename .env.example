# Root Docker Compose environment
# Copy this file to `.env` before running `yarn docker:up`.

# ── App / Proxy ──────────────────────────────────────────────────────
TZ=Asia/Seoul
SITE_URL=https://orot.dev
WEB_ORIGIN=https://orot.dev
HTTP_PORT=80

# ── Web Runtime / Public Client Vars ────────────────────────────────
# `NEXT_PUBLIC_*` values are baked into the Next.js client bundle.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SITE_URL=https://orot.dev
NEXT_PUBLIC_CLIENT_ERROR_LOGGING=true
CLIENT_ERROR_LOGGING=true
# Next.js server components(SSR)에서 API 호출에 사용하는 내부 origin.
# Docker 네트워크에서는 service DNS(orot-api)로 접근해야 함.
INTERNAL_API_ORIGIN=http://orot-api:4000

# ── Logging ──────────────────────────────────────────────────────────
HTTP_LOGGING=true
LOG_LEVEL=info
WEB_LOG_LEVEL=info
LOG_PRETTY=false
SLOW_QUERY_MS=300

# ── Studio Auth ──────────────────────────────────────────────────────
STUDIO_USERNAME=admin
STUDIO_PASSWORD=change-me

# ── MariaDB ──────────────────────────────────────────────────────────
DB_DATABASE=orot
DB_USERNAME=orot
DB_PASSWORD=orot-password
MARIADB_ROOT_PASSWORD=orot-root-password
DB_SEED_ON_DEPLOY=true

# ── JWT ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Cookies ──────────────────────────────────────────────────────────
COOKIE_DOMAIN=
COOKIE_SECURE=true
