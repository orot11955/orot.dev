# Root production / compose environment
# Copy to `.env.production` before building or deploying.

TZ=Asia/Seoul
HTTP_PORT=80

# Shared app URLs
SITE_URL=https://orot.dev
WEB_ORIGIN=https://orot.dev

# Shared logging
LOG_LEVEL=info
LOG_PRETTY=false

# Web app
WEB_LOG_LEVEL=info
WEB_LOG_PRETTY=false
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SITE_URL=https://orot.dev
NEXT_PUBLIC_CLIENT_ERROR_LOGGING=true
CLIENT_ERROR_LOGGING=true
INTERNAL_API_ORIGIN=http://orot-api:4000
WEB_SERVER_API_TIMEOUT_MS=3000
WEB_IMAGE_REMOTE_PATTERNS=https://orot.dev/uploads/**

# API app
API_HTTP_LOGGING=true
API_LOG_LEVEL=
API_LOG_PRETTY=
API_REQUEST_BODY_LIMIT=20mb
API_SLOW_QUERY_MS=300
API_STUDIO_USERNAME=admin
API_STUDIO_PASSWORD=change-me
API_JWT_ACCESS_SECRET=change-this-access-secret
API_JWT_REFRESH_SECRET=change-this-refresh-secret
API_JWT_ACCESS_EXPIRES_IN=15m
API_JWT_REFRESH_EXPIRES_IN=30d
API_COOKIE_DOMAIN=
API_COOKIE_SECURE=true

# Database / migrations
DB_DATABASE=orot
DB_USERNAME=orot
DB_PASSWORD=orot-password
MARIADB_ROOT_PASSWORD=orot-root-password
DB_SEED_ON_DEPLOY=true
DB_AUTO_BASELINE_LEGACY=true
