# Standalone API development
# Copy this file to `orot-api/.env` when running NestJS without Docker Compose.

# ── Server / Database ────────────────────────────────────────────────
PORT=4000
DATABASE_URL=mysql://orot:orotpassword@localhost:3306/orot

# ── Auth ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
STUDIO_USERNAME=admin
STUDIO_PASSWORD=your-admin-password

# ── App URLs / Cookies ───────────────────────────────────────────────
WEB_ORIGIN=http://localhost:3000
SITE_URL=http://localhost:3000
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ── Logging ──────────────────────────────────────────────────────────
HTTP_LOGGING=true
LOG_LEVEL=debug
LOG_PRETTY=false
SLOW_QUERY_MS=300
