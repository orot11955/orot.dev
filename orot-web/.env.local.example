# Standalone web development
# Copy this file to `orot-web/.env.local` when running Next.js without Docker Compose.

# ── App URLs ─────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Dev Proxy ────────────────────────────────────────────────────────
# Override this only when your local API is not running on localhost:4000.
INTERNAL_API_ORIGIN=http://localhost:4000

# ── Logging ──────────────────────────────────────────────────────────
NEXT_PUBLIC_CLIENT_ERROR_LOGGING=true
CLIENT_ERROR_LOGGING=true
LOG_LEVEL=debug
WEB_LOG_LEVEL=debug
LOG_PRETTY=false
