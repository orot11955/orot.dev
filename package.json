{
  "name": "orot.dev",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:all": "node ./scripts/dev.mjs",
    "dev:web": "yarn --cwd orot-web dev",
    "dev:api": "yarn --cwd orot-api start:dev",
    "build:web": "yarn --cwd orot-web build",
    "build:api": "yarn --cwd orot-api build",
    "build": "yarn build:api && yarn build:web",
    "lint:web": "yarn --cwd orot-web lint",
    "lint:api": "yarn --cwd orot-api lint",
    "lint": "yarn lint:api && yarn lint:web",
    "start:web": "yarn --cwd orot-web start",
    "start:api": "yarn --cwd orot-api start:prod",
    "db:generate": "yarn --cwd orot-api db:generate",
    "db:migrate:deploy": "yarn --cwd orot-api db:migrate:deploy",
    "db:push": "yarn --cwd orot-api db:push",
    "db:seed": "yarn --cwd orot-api db:seed",
    "docker:check": "./scripts/docker-stack.sh check",
    "docker:build": "./scripts/docker-stack.sh build",
    "docker:migrate": "./scripts/docker-stack.sh migrate",
    "docker:up": "./scripts/docker-stack.sh deploy",
    "docker:deploy": "./scripts/docker-stack.sh deploy",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  }
}
