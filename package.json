{
  "name": "orot.dev",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:all": "node ./scripts/dev.mjs",
    "dev:web": "node ./scripts/run-workspace.mjs development web dev",
    "dev:api": "node ./scripts/run-workspace.mjs development api start:dev",
    "build:web": "node ./scripts/run-workspace.mjs production web build",
    "build:api": "node ./scripts/run-workspace.mjs production api build",
    "build": "yarn build:api && yarn build:web",
    "test:api": "yarn --cwd orot-api test --runInBand",
    "test:e2e:api": "yarn --cwd orot-api test:e2e --runInBand",
    "test:ci": "yarn lint && yarn test:api && yarn test:e2e:api && yarn build",
    "lint:web": "yarn --cwd orot-web lint",
    "lint:api": "yarn --cwd orot-api lint",
    "lint": "yarn lint:api && yarn lint:web",
    "start:web": "node ./scripts/run-workspace.mjs production web start",
    "start:api": "node ./scripts/run-workspace.mjs production api start:prod",
    "db:generate": "node ./scripts/run-workspace.mjs development api db:generate",
    "db:migrate:deploy": "node ./scripts/run-workspace.mjs development api db:migrate:deploy",
    "db:push": "node ./scripts/run-workspace.mjs development api db:push",
    "db:seed": "node ./scripts/run-workspace.mjs development api db:seed",
    "docker:check": "./scripts/docker-stack.sh check",
    "docker:build": "./scripts/docker-stack.sh build",
    "docker:migrate": "./scripts/docker-stack.sh migrate",
    "docker:up": "./scripts/docker-stack.sh deploy",
    "docker:deploy": "./scripts/docker-stack.sh deploy",
    "docker:down": "./scripts/docker-compose-env.sh down",
    "docker:logs": "./scripts/docker-compose-env.sh logs -f",
    "docker:demo:up": "docker compose --env-file .env.demo -f docker-compose.demo-web.yml up -d --build",
    "docker:demo:down": "docker compose --env-file .env.demo -f docker-compose.demo-web.yml down",
    "docker:demo:logs": "docker compose --env-file .env.demo -f docker-compose.demo-web.yml logs -f",
    "docker:all:up": "./scripts/docker-stack.sh deploy && docker compose --env-file .env.demo -f docker-compose.demo-web.yml up -d --build"
  },
  "dependencies": {}
}
